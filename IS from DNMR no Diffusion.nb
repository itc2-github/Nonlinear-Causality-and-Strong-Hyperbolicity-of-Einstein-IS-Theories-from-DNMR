Cell["\<\
This calculation reproduces and directly generalizes the original nonlinear \
Israel-Stewart causality constraint with bulk in Bemfica et. al. 2019.\
\>", "Text",
 CellChangeTimes->{{3.992005658771887*^9, 
  3.992005719397915*^9}},ExpressionUUID->"a2b95029-4b1a-d443-a70e-\
2448b4d4b844"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparing with the zero Baryon-Current case", "Section",
 CellChangeTimes->{{3.9265997068369656`*^9, 3.926599720988185*^9}, {
  3.926599909268198*^9, 
  3.926599919964365*^9}},ExpressionUUID->"1f3fd40e-9a20-4a83-a162-\
defefa08ecd7"],

Cell[TextData[{
 "Define the terms used in Bemfica et. al. 2020: ",
 StyleBox["This should compile and output zero!",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.926599903855794*^9, 3.9265999054349303`*^9}, {
  3.926599964513932*^9, 3.9265999752531815`*^9}, {3.9273935468129997`*^9, 
  3.927393557020261*^9}, {3.9273936415998015`*^9, 
  3.927393651131954*^9}},ExpressionUUID->"3f168347-c5f2-44e2-abb1-\
d3b873f195bf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Useful", " ", "global", " ", "definitions", " ", "used", " ", "in", " ", 
    "the", " ", "original", " ", "paper"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"G", "[", "\[Beta]_", "]"}], ":=", 
     FractionBox[
      RowBox[{
       RowBox[{"2", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "\[Eta]"}], "+", 
          RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
         ")"}]}], "+", 
       RowBox[{"\[Tau]\[Pi]\[Pi]", " ", 
        RowBox[{"\[CapitalLambda]", "[", 
         RowBox[{"[", "\[Beta]", "]"}], "]"}]}]}], 
      RowBox[{"4", "E0", " ", "\[Tau]\[Pi]"}]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"E0", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["x", "2"], "-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"G", "[", "2", "]"}], 
             SuperscriptBox["v1", "2"]}], "+", 
            RowBox[{
             RowBox[{"G", "[", "3", "]"}], 
             SuperscriptBox["v2", "2"]}], "+", 
            RowBox[{
             RowBox[{"G", "[", "4", "]"}], 
             SuperscriptBox["v3", "2"]}]}], ")"}]}], ")"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"E0", "+", "\[CapitalLambda]1"}], ")"}], 
         SuperscriptBox["x", "2"]}], "-", 
        FractionBox[
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "\[Eta]"}], "+", 
            RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
           ")"}], 
          SuperscriptBox["v", "2"]}], 
         RowBox[{"2", "\[Tau]\[Pi]"}]], "-", 
        FractionBox[
         RowBox[{"\[Tau]\[Pi]\[Pi]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[CapitalLambda]1", " ", 
             SuperscriptBox["v", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]1", " ", 
             SuperscriptBox["v1", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]2", " ", 
             SuperscriptBox["v2", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]3", " ", 
             SuperscriptBox["v3", "2"]}]}], ")"}]}], 
         RowBox[{"4", "\[Tau]\[Pi]"}]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"E0", "+", "\[CapitalLambda]2"}], ")"}], 
         SuperscriptBox["x", "2"]}], "-", 
        FractionBox[
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "\[Eta]"}], "+", 
            RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
           ")"}], 
          SuperscriptBox["v", "2"]}], 
         RowBox[{"2", "\[Tau]\[Pi]"}]], "-", 
        FractionBox[
         RowBox[{"\[Tau]\[Pi]\[Pi]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[CapitalLambda]2", " ", 
             SuperscriptBox["v", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]1", " ", 
             SuperscriptBox["v1", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]2", " ", 
             SuperscriptBox["v2", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]3", " ", 
             SuperscriptBox["v3", "2"]}]}], ")"}]}], 
         RowBox[{"4", "\[Tau]\[Pi]"}]]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"E0", "+", "\[CapitalLambda]3"}], ")"}], 
         SuperscriptBox["x", "2"]}], "-", 
        FractionBox[
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "\[Eta]"}], "+", 
            RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
           ")"}], 
          SuperscriptBox["v", "2"]}], 
         RowBox[{"2", "\[Tau]\[Pi]"}]], "-", 
        FractionBox[
         RowBox[{"\[Tau]\[Pi]\[Pi]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[CapitalLambda]3", " ", 
             SuperscriptBox["v", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]1", " ", 
             SuperscriptBox["v1", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]2", " ", 
             SuperscriptBox["v2", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]3", " ", 
             SuperscriptBox["v3", "2"]}]}], ")"}]}], 
         RowBox[{"4", "\[Tau]\[Pi]"}]]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", "\[Beta]_", "]"}], ":=", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"2", "\[Eta]"}], "+", 
        RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", "\[Delta]\[Pi]\[Pi]"}], "-", "\[Tau]\[Pi]\[Pi]"}], 
          ")"}], 
         RowBox[{"\[CapitalLambda]", "[", 
          RowBox[{"[", "\[Beta]", "]"}], "]"}]}]}], 
       RowBox[{"6", "\[Tau]\[Pi]"}]], "+", 
      FractionBox[
       RowBox[{"\[Zeta]", "+", 
        RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", " ", "\[CapitalPi]"}], "+", 
        RowBox[{"\[Lambda]\[CapitalPi]\[Pi]", " ", 
         RowBox[{"\[CapitalLambda]", "[", 
          RowBox[{"[", "\[Beta]", "]"}], "]"}]}]}], "\[Tau]\[CapitalPi]"], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"E0", "+", 
         RowBox[{"\[CapitalLambda]", "[", 
          RowBox[{"[", "\[Beta]", "]"}], "]"}]}], ")"}], "Pe"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NoCurrentDet", "=", 
     RowBox[{
      RowBox[{"m", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"m", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "*", " ", 
         RowBox[{"m", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "*", 
         RowBox[{"m", "[", 
          RowBox[{"[", "4", "]"}], "]"}]}], "-", 
        RowBox[{
         SuperscriptBox["v1", "2"], "*", " ", 
         RowBox[{"m", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "*", 
         RowBox[{"m", "[", 
          RowBox[{"[", "4", "]"}], "]"}], "*", 
         RowBox[{"A", "[", "2", "]"}]}], "-", " ", 
        RowBox[{
         RowBox[{"m", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "*", " ", 
         SuperscriptBox["v2", "2"], "*", 
         RowBox[{"m", "[", 
          RowBox[{"[", "4", "]"}], "]"}], "*", 
         RowBox[{"A", "[", "3", "]"}]}], "-", " ", 
        RowBox[{
         RowBox[{"m", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "*", " ", 
         RowBox[{"m", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "*", 
         SuperscriptBox["v3", "2"], "*", 
         RowBox[{"A", "[", "4", "]"}]}], "-", 
        RowBox[{
         RowBox[{"(", 
          FractionBox[
           RowBox[{
            RowBox[{"12", "\[Delta]\[Pi]\[Pi]"}], "-", "\[Tau]\[Pi]\[Pi]"}], 
           RowBox[{"12", "\[Tau]\[Pi]"}]], ")"}], 
         RowBox[{"(", 
          RowBox[{
           FractionBox["\[Lambda]\[CapitalPi]\[Pi]", "\[Tau]\[CapitalPi]"], "+",
            "Pe", "-", 
           FractionBox["\[Tau]\[Pi]\[Pi]", 
            RowBox[{"12", "\[Tau]\[Pi]"}]]}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"m", "[", 
             RowBox[{"[", "4", "]"}], "]"}], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[CapitalLambda]1", "-", "\[CapitalLambda]2"}], ")"}], 
             "2"], 
            SuperscriptBox["v1", "2"], 
            SuperscriptBox["v2", "2"]}], "+", " ", 
           RowBox[{
            RowBox[{"m", "[", 
             RowBox[{"[", "3", "]"}], "]"}], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[CapitalLambda]1", "-", "\[CapitalLambda]3"}], ")"}], 
             "2"], 
            SuperscriptBox["v1", "2"], 
            SuperscriptBox["v3", "2"]}], "+", " ", 
           RowBox[{
            RowBox[{"m", "[", 
             RowBox[{"[", "2", "]"}], "]"}], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[CapitalLambda]2", "-", "\[CapitalLambda]3"}], ")"}], 
             "2"], 
            SuperscriptBox["v2", "2"], 
            SuperscriptBox["v3", "2"]}]}], ")"}]}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Simplify", "[", 
    RowBox[{"NoCurrentDet", "-", 
     RowBox[{"Det", "[", 
      RowBox[{
       RowBox[{"x", "*", "Xtilde"}], "+", 
       RowBox[{"n", " ", "Pn", " ", 
        RowBox[{"TensorProduct", "[", 
         RowBox[{"vA", ",", "yB"}], "]"}]}]}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.926599987330449*^9, 3.9266000216173277`*^9}, {
   3.926600116897504*^9, 3.9266002296036353`*^9}, {3.9266002737988167`*^9, 
   3.926600465650082*^9}, {3.926600496549133*^9, 3.9266007312402105`*^9}, {
   3.9266007869699774`*^9, 3.9266009806110373`*^9}, {3.9266010198571663`*^9, 
