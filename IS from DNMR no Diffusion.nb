Notebook[{

Cell[CellGroupData[{
Cell["\<\
Nonlinear Causality and Strong Hyperbolicity of Einstein-Israel-Stewart \
Theories of Transient Relativistic Fluid Dynamics (Calculations)\
\>", "Title",
 CellChangeTimes->{{3.92426922538381*^9, 3.9242692362351856`*^9}, {
  3.9920013651137714`*^9, 
  3.992001377327688*^9}},ExpressionUUID->"7b130b4c-4e47-4466-bfd7-\
26c25e2d9c66"],

Cell["\<\
Mathematica Notebook by Ian Cordeiro
Last Edit: 2 July 2026
Contact Info: itc2@illinois.edu\
\>", "Text",
 CellChangeTimes->{{3.992001587503834*^9, 3.9920016208948326`*^9}, {
  3.992001680443779*^9, 
  3.992001689126423*^9}},ExpressionUUID->"8f628def-2978-9146-8ded-\
34d548f3ea23"],

Cell[CellGroupData[{

Cell["Global Unit Definitions (PLEASE READ)", "Chapter",
 CellChangeTimes->{{3.894544841418065*^9, 3.894544854328527*^9}, {
   3.894634815837508*^9, 3.8946348178392467`*^9}, {3.894635090762486*^9, 
   3.894635094596484*^9}, {3.9920034066369667`*^9, 3.99200341171558*^9}, 
   3.992010098996994*^9},ExpressionUUID->"2e85b4e7-2646-4e3d-9d38-\
053f92586038"],

Cell[TextData[{
 "Notice that we are working in units of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"E", "=", 
    RowBox[{
     SubscriptBox["\[Tau]", "\[Pi]"], "=", 
     RowBox[{
      SubscriptBox["\[Tau]", "\[CapitalPi]"], "=", "1"}]}]}], 
   TraditionalForm]],ExpressionUUID->"0fa6af44-1f99-0944-85a6-dd48f22f41ea"],
 " (note that we call E0 = E = e + P + \[CapitalPi]), which is the same as \
redefining the transport coefficients and dynamic variables such that\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Zeta]", ",", 
      SubscriptBox["\[Delta]", "\[CapitalPi]\[CapitalPi]"], ",", " ", 
      SubscriptBox["\[Lambda]", "\[CapitalPi]\[Pi]"]}], ")"}], " ", "->"}], 
   TraditionalForm]],ExpressionUUID->"91580d4e-189d-8742-88e1-ce5a1b41f73b"],
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["\[Tau]", "\[CapitalPi]"]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["\[Zeta]", "E"], ",", 
       SubscriptBox["\[Delta]", "\[CapitalPi]\[CapitalPi]"], ",", " ", 
       SubscriptBox["\[Lambda]", "\[CapitalPi]\[Pi]"]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"b7d2d422-2a5b-aa48-a6bd-c43322b6cb62"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Eta]", ",", 
      SubscriptBox["\[Delta]", "\[Pi]\[Pi]"], ",", " ", 
      SubscriptBox["\[Tau]", "\[Pi]\[Pi]"], ",", " ", 
      SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"]}], ")"}], " ", "->"}], 
   TraditionalForm]],ExpressionUUID->"82aa8aec-8a76-504d-b6c3-dc3486b391d8"],
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["\[Tau]", "\[Pi]"]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["\[Eta]", "E"], ",", 
       SubscriptBox["\[Delta]", "\[Pi]\[Pi]"], ",", " ", 
       SubscriptBox["\[Tau]", "\[Pi]\[Pi]"], ",", " ", 
       SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"]}], ")"}], " "}]}], 
   TraditionalForm]],ExpressionUUID->"c5da5077-6632-2e4e-b000-25c6be4e97ca"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalLambda]", "a"], "->", 
    FractionBox[
     SubscriptBox["\[CapitalLambda]", "a"], "E"]}], TraditionalForm]],
  ExpressionUUID->"ffaa023b-3760-f847-9fb7-faf1a70c39ed"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalPi]", "->", 
    FractionBox["\[CapitalPi]", "E"]}], TraditionalForm]],ExpressionUUID->
  "b2e3e060-0fad-5941-aceb-68d1476b529f"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", " ", 
     SubscriptBox["P", "n"]}], "->", 
    FractionBox[
     RowBox[{"n", " ", 
      SubscriptBox["P", "n"]}], "E"]}], TraditionalForm]],ExpressionUUID->
  "1656e37a-e577-7f4d-8d81-8ff679d735db"],
 "\n\nTrimming the amount of symbolic terms will make the calculation run \
quicker.\n\n***Note that we also normalize the characteristic vector \
components via ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["v", "2"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalDelta]", "\[Alpha]\[Beta]"], 
      SubscriptBox["\[Phi]", "\[Alpha]"], 
      SubscriptBox["\[Phi]", "\[Beta]"]}], "=", "1"}]}], TraditionalForm]],
  ExpressionUUID->"02a11506-04ac-6f49-87d3-4e551c43107b"],
 ", which amounts to writing \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["x", "2"], "->", 
    FractionBox[
     SuperscriptBox["x", "2"], 
     SuperscriptBox["v", "2"]]}], TraditionalForm]],ExpressionUUID->
  "9dd52c5d-d741-cb4f-b419-6b045c46b70f"],
 ", \n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["v", "A"], "2"], "->", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["v", "A"], "2"], 
     SuperscriptBox["v", "2"]]}], TraditionalForm]],ExpressionUUID->
  "37ee2721-0740-8740-9330-7a307963ac4f"],
 ".\n\nWe\[CloseCurlyQuote]ll also often write y = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "25bb21fd-b43c-d944-a195-00669b135a66"],
 " for aesthetic purposes."
}], "Text",
 CellChangeTimes->{{3.929201576556391*^9, 3.9292017420566645`*^9}, {
   3.929202222065114*^9, 3.929202244276492*^9}, {3.934539091813116*^9, 
   3.934539121130993*^9}, {3.9403447930140533`*^9, 3.9403448253337364`*^9}, {
   3.956063365867159*^9, 3.95606338733729*^9}, {3.9560635028166046`*^9, 
   3.9560637089673195`*^9}, {3.9560642941420803`*^9, 3.956064549274103*^9}, {
   3.992002399830721*^9, 3.992002445131668*^9}, 3.9920024809295387`*^9, {
   3.9920025220960007`*^9, 3.992002645771759*^9}, {3.9920029910804195`*^9, 
   3.9920030110806007`*^9}},ExpressionUUID->"40c82e9d-e9e2-2647-b15b-\
eabf8fa3eaf7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Determinant of Reduced Principal Part in the Basis of Eigenvectors (with \
Baryon Current):\
\>", "Chapter",
 CellChangeTimes->{{3.926001532405986*^9, 3.926001590717676*^9}, {
  3.927393377909457*^9, 
  3.9273933840756598`*^9}},ExpressionUUID->"c5c600f0-2f2d-4bf8-a3d2-\
d6d02572e612"],

Cell[TextData[{
 "In this section, we are finding the determinant of the 4 x 4 matrix ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "~"], TraditionalForm]],ExpressionUUID->
  "59c0d9b7-2726-4dd9-aba9-11f746043117"],
 ", which is related to the principal part  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "\[Alpha]"], 
    SubscriptBox["\[Phi]", "\[Alpha]"]}], TraditionalForm]],ExpressionUUID->
  "e761ed9b-ba34-4144-953e-46955f5a6173"],
 " via the relationship\n\ndet(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "\[Alpha]"], 
    SubscriptBox["\[Phi]", "\[Alpha]"]}], TraditionalForm]],ExpressionUUID->
  "bcf33a16-9707-4efe-a1e3-d58d49abab67"],
 ") = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "\[CapitalPi]"], 
    SuperscriptBox[
     SubscriptBox["\[Tau]", "\[Pi]"], "16"], 
    SuperscriptBox["x", "19"], 
    RowBox[{"det", "(", 
     FormBox[
      OverscriptBox["X", "~"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "adaff830-b7f0-454b-81f2-5a07739faa0e"],
 "\n\nwhere  ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "~"], TraditionalForm]],ExpressionUUID->
  "28f8582b-f04e-408b-acb0-71e1b1a12291"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["Y", 
     RowBox[{"-", "1"}]], "XY"}], TraditionalForm]],ExpressionUUID->
  "d1d0177d-3e5d-4eb3-aa58-15f6671fd6ee"],
 " is the transformed matrix in the orthonormal basis of eigenvectors of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Pi]", "\[Mu]\[Nu]"], TraditionalForm]],ExpressionUUID->
  "a6d0efcc-0b7f-42d1-a79b-61a344d6b759"],
 ". Recall that by cyclic properties of the determinant, det(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["X", "~"], ")"}], "=", 
    RowBox[{"det", "(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "9cf2db7e-9aac-4755-bce1-cc1a85ddc4e2"],
 ". Below, we upload the matrix into Mathematica. A denotes a raised (row) \
index, B denotes a lowered (column) index unless otherwise stated."
}], "Text",
 CellChangeTimes->{{3.9260016118802795`*^9, 3.926001907327442*^9}, {
  3.92600204695782*^9, 3.9260021096058855`*^9}, {3.928093203864658*^9, 
  3.9280932049255495`*^9}},ExpressionUUID->"3ae09fdf-7906-4bb4-9b81-\
fde6840b446f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Identity", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Delta]", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Set", " ", "relaxation", " ", "times", " ", "and", " ", "E0"}], 
     " ", "=", " ", 
     RowBox[{"\[CurlyEpsilon]", " ", "+", " ", "P", " ", "+", " ", 
      RowBox[{"\[CapitalPi]", " ", "to", " ", "unity", " ", 
       RowBox[{"(", 
        RowBox[{
        "amounts", " ", "to", " ", "a", " ", "redefinition", " ", "of", " ", 
         "the", " ", "transport", " ", "coeffs"}], ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Tau]\[Pi]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Tau]\[CapitalPi]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"E0", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Minkowski", " ", "metric", " ", "inverse", " ", 
     SuperscriptBox["\[Eta]", "AB"], " ", "with", " ", "raised", " ", 
     RowBox[{"indices", ".", " ", 
      RowBox[{"Note", ":", " ", 
       RowBox[{
       "this", " ", "metric", " ", "is", " ", "with", " ", "respect", " ", 
        "to", " ", "the", " ", "shear", " ", "stress", " ", "tensor", " ", 
        "eigenbasis"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Eta]AB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";"}], 
   " ", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Projections", " ", "onto", " ", "the", " ", "characteristic", " ", 
       RowBox[{"vector", ":", " ", 
        SubscriptBox["y", "A"]}]}], " ", "=", " ", 
      RowBox[{
       SubscriptBox["\[Phi]", "\[Alpha]"], 
       SuperscriptBox[
        SubscriptBox["e", "A"], "\[Alpha]"]}]}], ",", " ", 
     RowBox[{
      SubscriptBox["v", "A"], " ", "=", " ", 
      RowBox[{
       SubscriptBox["v", "\[Alpha]"], 
       SuperscriptBox[
        SubscriptBox["e", "A"], "\[Alpha]"]}]}], ",", " ", 
     RowBox[{
      SubscriptBox["y", "0"], " ", "=", " ", "x"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vB", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", "v1", ",", "v2", ",", "v3"}], "}"}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vA", "=", 
     RowBox[{"\[Eta]AB", ".", "vB"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yB", "=", 
     RowBox[{"{", 
      RowBox[{"x", ",", "v1", ",", "v2", ",", "v3"}], "}"}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yA", "=", 
     RowBox[{"\[Eta]AB", ".", "yB"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"v", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"vB", ".", "vA"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Convenient", " ", "substitutions", " ", "for", " ", "inputting", " ", 
     "the", " ", "eigenvalues", " ", 
     SubscriptBox["\[CapitalLambda]", "A"]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]", "=", 
     RowBox[{"{", 
      RowBox[{
      "0", ",", "\[CapitalLambda]1", ",", "\[CapitalLambda]2", ",", 
       "\[CapitalLambda]3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]yB", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"\[CapitalLambda]1", " ", "v1"}], ",", 
       RowBox[{"\[CapitalLambda]2", " ", "v2"}], ",", 
       RowBox[{"\[CapitalLambda]3", " ", "v3"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]yA", "=", 
     RowBox[{"\[Eta]AB", ".", "\[CapitalLambda]yB"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]\[Delta]AB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "\[CapitalLambda]1", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "\[CapitalLambda]2", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "\[CapitalLambda]3"}], "}"}]}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Substitutions", " ", "stemming", " ", "from", " ", "coefficients", " ", 
     "of", " ", "the", " ", "original", " ", "principal", " ", "part"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"C\[CapitalPi]B", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Zeta]", "+", 
         RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
        ")"}], "yB"}], "+", 
      RowBox[{"\[Lambda]\[CapitalPi]\[Pi]", " ", "\[CapitalLambda]yB"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"C\[Pi]AB", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "\[Eta]"}], "+", 
         RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], ")"}],
        "*", 
       RowBox[{"(", 
        RowBox[{
         FractionBox[
          RowBox[{"TensorProduct", "[", 
           RowBox[{"vA", ",", "yB"}], "]"}], "6"], "+", 
         FractionBox[
          RowBox[{
           SuperscriptBox["v", "2"], "\[Delta]"}], "2"]}], ")"}]}], "-", 
      RowBox[{"\[Tau]\[Pi]", " ", "x", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"TensorProduct", "[", 
          RowBox[{
           RowBox[{"\[Delta]", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
           "\[CapitalLambda]yB"}], "]"}], "+", 
         RowBox[{"x", " ", "\[CapitalLambda]\[Delta]AB"}]}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Delta]\[Pi]\[Pi]", "-", 
         FractionBox["\[Tau]\[Pi]\[Pi]", "12"]}], ")"}], 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"\[CapitalLambda]yA", ",", "yB"}], "]"}]}], "+", 
      RowBox[{
       FractionBox["\[Tau]\[Pi]\[Pi]", "4"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["v", "2"], " ", "\[CapitalLambda]\[Delta]AB"}], "+", 
         RowBox[{"\[Delta]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[CapitalLambda]1", " ", 
             SuperscriptBox["v1", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]2", " ", 
             SuperscriptBox["v2", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]3", " ", 
             SuperscriptBox["v3", "2"]}]}], ")"}]}]}], ")"}]}], "-", 
      RowBox[{
       FractionBox["\[Tau]\[Pi]\[Pi]", "12"], 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"vA", ",", "\[CapitalLambda]yB"}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"X", " ", "in", " ", "the", " ", "basis", " ", 
     RowBox[{"{", 
      SuperscriptBox[
       SubscriptBox["e", "A"], "\[Mu]"], "}"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Xtilde", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"E0", " ", "x", " ", "\[Delta]"}], "-", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{
         RowBox[{"\[Delta]", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
         "\[CapitalLambda]yB"}], "]"}], "-", 
       RowBox[{
        FractionBox["Pe", "x"], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"E0", " ", 
           RowBox[{"TensorProduct", "[", 
            RowBox[{"vA", ",", "yB"}], "]"}]}], "+", 
          RowBox[{"TensorProduct", "[", 
           RowBox[{"vA", ",", "\[CapitalLambda]yB"}], "]"}]}], ")"}]}], "-", 
       RowBox[{
        FractionBox[
         RowBox[{"n", " ", "Pn"}], "x"], 
        RowBox[{"TensorProduct", "[", 
         RowBox[{"vA", ",", "yB"}], "]"}]}], "-", 
       FractionBox[
        RowBox[{"TensorProduct", "[", 
         RowBox[{"vA", ",", "C\[CapitalPi]B"}], "]"}], 
        RowBox[{"\[Tau]\[CapitalPi]", " ", "x"}]], "-", 
       FractionBox["C\[Pi]AB", 
        RowBox[{"\[Tau]\[Pi]", " ", "x"}]]}], ")"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Fully", " ", "nonlinear", " ", "characteristic", " ", 
       RowBox[{"polynomial", ".", " ", "We"}], " ", "suppress", " ", "it", " ",
        "for", " ", 
       RowBox[{"brevity", ".", " ", "Let"}], " ", "y"}], " ", "=", " ", 
      RowBox[{
       RowBox[{
        SuperscriptBox["x", "2"], ".", " ", "Note"}], " ", "that", " ", "we", 
       " ", "are", " ", "dividing", " ", "by", " ", "multiple"}]}], ",", " ", 
     RowBox[{
     "simpler", " ", "polynomials", " ", "present", " ", "in", " ", "the", " ",
       "characteristic", " ", 
      RowBox[{"determinant", ".", " ", "These"}], " ", "prefactors", " ", 
      "are", " ", "written", " ", "in", " ", "the", " ", "main", " ", 
      RowBox[{"paper", "."}]}]}], "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FullCubic", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Cancel", "[", 
        RowBox[{
         RowBox[{"Det", "[", 
          RowBox[{"x", " ", "Xtilde"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"E0", " ", 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox["x", "2"], "-", 
             FractionBox[
              RowBox[{
               SuperscriptBox["v1", "2"], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", " ", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"2", " ", "\[Eta]"}], "+", 
                    RowBox[{
                    "\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
                   ")"}]}], "+", 
                 RowBox[{"\[CapitalLambda]1", " ", "\[Tau]\[Pi]\[Pi]"}]}], 
                ")"}]}], 
              RowBox[{"4", " ", "E0", " ", "\[Tau]\[Pi]"}]], "-", 
             FractionBox[
              RowBox[{
               SuperscriptBox["v2", "2"], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", " ", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"2", " ", "\[Eta]"}], "+", 
                    RowBox[{
                    "\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
                   ")"}]}], "+", 
                 RowBox[{"\[CapitalLambda]2", " ", "\[Tau]\[Pi]\[Pi]"}]}], 
                ")"}]}], 
              RowBox[{"4", " ", "E0", " ", "\[Tau]\[Pi]"}]], "-", 
             FractionBox[
              RowBox[{
               SuperscriptBox["v3", "2"], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", " ", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"2", " ", "\[Eta]"}], "+", 
                    RowBox[{
                    "\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
                   ")"}]}], "+", 
                 RowBox[{"\[CapitalLambda]3", " ", "\[Tau]\[Pi]\[Pi]"}]}], 
                ")"}]}], 
              RowBox[{"4", " ", "E0", " ", "\[Tau]\[Pi]"}]]}], ")"}], 
           RowBox[{"(", 
            RowBox[{"E0", "+", "\[CapitalLambda]1"}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"E0", "+", "\[CapitalLambda]2"}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"E0", "+", "\[CapitalLambda]3"}], ")"}]}], " ", ")"}]}], 
        "]"}], ")"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "->", 
         RowBox[{"Sqrt", "[", "y", "]"}]}], ",", 
        RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", "->", "0"}]}], "}"}]}]}], 
    ";"}]}]}]], "Input",
