Cell[TextData[{
 "There are a few combinations of scalars that appear frequently together as \
nonlinear corrections to equilibrium quantities. We shall introduce the \
definitions\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "A"], "=", 
    RowBox[{"E", "+", 
     SubscriptBox["\[CapitalLambda]", "A"]}]}], TraditionalForm]],
  ExpressionUUID->"8446919b-f9be-b249-b952-f9c7d73e792c"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Zeta]", "eff"], "=", 
    RowBox[{"\[Zeta]", "+", 
     RowBox[{"n", " ", 
      SubscriptBox["P", "n"]}], "+", 
     RowBox[{
      SubscriptBox["\[Delta]", "\[CapitalPi]\[CapitalPi]"], 
      "\[CapitalPi]"}]}]}], TraditionalForm]],ExpressionUUID->
  "6bb59cc2-ddf4-e947-8cdb-b401cfb2c381"],
 " + ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Eta]", "eff"], "/", "3"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c11b3ad2-d14d-ae43-af9f-03e426f09deb"],
 "\n\nAlthough ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "800d6b5e-06d1-b243-abd6-d3ca128c0ad5"],
 " is set to zero below, you should interpret any mention of \[Eta] instead \
as the generalized term \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Eta]", "->", 
     SubscriptBox["\[Eta]", "eff"]}], "=", 
    RowBox[{"\[Eta]", "+", 
     FractionBox[
      RowBox[{
       SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"], "\[CapitalPi]"}], 
      "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "93d3ba89-0346-7b49-918b-96c3e107efc5"],
 "\n\nThis substitution is another redefinition that is made to streamline \
the output a bit.\n\nNext, we extract the coefficients of the cubic in order \
to manually find the discriminant. A simple way of doing this is to determine \
the coefficients P and Q of the depressed cubic. We don\[CloseCurlyQuote]t \
use the ",
 StyleBox["Discriminant", "Code"],
 " function here since it outputs a large text file that is difficult to \
manage. Here, An[[n+1]] are the coefficients of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", "n"], TraditionalForm]],ExpressionUUID->
  "d98cd5af-6b43-a142-a131-cad32597447a"],
 ", with ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", "3"], TraditionalForm]],ExpressionUUID->
  "9a010703-d772-2a44-ab1d-d4c25cf25de3"],
 " having a coefficient of 1 by construction. Please be patient here - ",
 StyleBox["FullSimplify", "Code"],
 " seems to take a couple of minutes to compile."
}], "Text",
 CellChangeTimes->{{3.929201576556391*^9, 3.9292017420566645`*^9}, {
   3.929202222065114*^9, 3.929202244276492*^9}, {3.934539091813116*^9, 
   3.934539121130993*^9}, {3.9403447930140533`*^9, 3.9403448253337364`*^9}, {
   3.956063365867159*^9, 3.95606338733729*^9}, {3.9560635028166046`*^9, 
   3.9560637089673195`*^9}, {3.9560642941420803`*^9, 3.956064549274103*^9}, {
   3.992002399830721*^9, 3.9920024328960876`*^9}, {3.9920027688097954`*^9, 
   3.9920027702283516`*^9}, {3.992005252431076*^9, 3.992005259032278*^9}, {
   3.992010717168413*^9, 3.9920107565390167`*^9}, {3.9920107984667454`*^9, 
   3.9920108297675095`*^9}, 
   3.9920110058645687`*^9},ExpressionUUID->"5d6310d8-2331-5343-8313-\
8918d9571c97"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "List", " ", "of", " ", "effective", " ", "corrections", " ", "that", " ", 
    "we", " ", "will", " ", "use", " ", "to", " ", "simplify", " ", "the", " ",
     "determinant"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"EffTerms", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalLambda]1", "->", 
        RowBox[{"x1", "-", "E0"}]}], ",", 
       RowBox[{"\[CapitalLambda]2", "->", 
        RowBox[{"x2", "-", "E0"}]}], ",", 
       RowBox[{"\[CapitalLambda]3", "->", 
        RowBox[{"x3", "-", "E0"}]}], ",", 
       RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", "->", "0"}], ",", 
       RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", "->", 
        FractionBox[
         RowBox[{"\[Zeta]eff", "-", "\[Zeta]", "-", 
          RowBox[{"n", " ", "Pn"}], "-", 
          RowBox[{"\[Eta]", "/", "3"}]}], "\[CapitalPi]"]}]}], " ", "}"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Upload", " ", "the", " ", "cubic", " ", "coefficients"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"An", "=", 
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"x1", "+", "x2", "+", "x3"}], "==", "3"}], ",", 
         RowBox[{
          RowBox[{
           SuperscriptBox["v1", "2"], "+", 
           SuperscriptBox["v2", "2"], "+", 
           SuperscriptBox["v3", "2"]}], "==", "1"}]}], "}"}], ",", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"CoefficientList", "[", 
          RowBox[{"FullCubic", ",", "y"}], "]"}], "/.", "EffTerms"}], "]"}]}],
       "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"An", "=", 
     RowBox[{"Collect", "[", 
      RowBox[{
       RowBox[{"Cancel", "[", 
        RowBox[{"An", "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"v3", "->", 
            RowBox[{"Sqrt", "[", "\[Kappa]", "]"}]}], ",", 
           RowBox[{"v2", "->", 
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", "\[Kappa]"}], ")"}], 
              RowBox[{"(", 
               RowBox[{"1", "-", "\[Chi]"}], ")"}]}], "]"}]}], ",", 
           RowBox[{"v1", "->", 
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "-", "\[Kappa]"}], ")"}], "\[Chi]"}], "]"}]}]}], 
          "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
        "\[Zeta]eff", ",", "\[Lambda]\[CapitalPi]\[Pi]", ",", "\[Eta]eff", ",",
          "\[Delta]\[Pi]\[Pi]", ",", "\[Tau]\[Pi]\[Pi]"}], "}"}], ",", 
       "FullSimplify"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<The following conditions are necessary and sufficient for \
the roots to be non-negative\>\"", ",", "\"\<\\n\\n\>\""}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<0 \[LessEqual] \!\(\*FractionBox[SubscriptBox[\(A\), \(2\)], \
\(3\)]\) \[LessEqual] 1\>\"", 
     ",", "\"\< where \!\(\*FractionBox[SubscriptBox[\(A\), \(2\)], \(3\)]\) \
= \>\"", ",", 
     FractionBox[
      RowBox[{"-", 
       RowBox[{"An", "[", 
        RowBox[{"[", "3", "]"}], "]"}]}], "3"]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<0 \[LessEqual] \!\(\*SubscriptBox[\(A\), \(1\)]\) = \>\"", ",", 
     RowBox[{"An", "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<0 \[LessEqual] \!\(\*SubscriptBox[\(A\), \(0\)]\) = \>\"", ",", 
     RowBox[{"-", 
      RowBox[{"An", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.933872138245413*^9, 3.933872168396595*^9}, {
