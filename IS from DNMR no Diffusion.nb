   3.9560640016886845`*^9, 3.956064010045515*^9}, 3.9560641203468857`*^9, {
   3.9560650568415833`*^9, 3.956065075198309*^9}, 3.9920030979199276`*^9, 
   3.9920046009225903`*^9, {3.9920052728009033`*^9, 3.992005302550516*^9}, {
   3.99201073693293*^9, 3.992010737161724*^9}, {3.9920107697767735`*^9, 
   3.9920107728368263`*^9}},
