Cell["\<\
Here is the the characteristic determinant without any shear contributions\
\>", "Text",
 CellChangeTimes->{{3.9279906639874725`*^9, 3.9279906961164184`*^9}, {
  3.9280851272293177`*^9, 3.9280851425067015`*^9}, {3.9920056121547165`*^9, 
  3.9920056313300858`*^9}},ExpressionUUID->"49787c9f-29b2-9b43-a9ff-\
b6af5e63602e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"BBFullDet", "[", "x_", "]"}], ":=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"\[Tau]\[CapitalPi]", " ", 
      SuperscriptBox["x", "3"], 
      RowBox[{"Det", "[", 
       RowBox[{"Xtilde", "+", 
        FractionBox["C\[Pi]AB", 
         RowBox[{"x", " ", "\[Tau]\[Pi]"}]]}], "]"}]}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", "->", "0"}], ",", 
       RowBox[{"\[Lambda]\[CapitalPi]\[Pi]", "->", "0"}], ",", 
       RowBox[{"\[Delta]\[Pi]\[Pi]", "->", "0"}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", "->", "0"}], ","}], 
        "*)"}], 
       RowBox[{"\[Tau]\[Pi]\[Pi]", "->", "0"}], ",", 
       RowBox[{"\[CapitalLambda]1", "->", "0"}], ",", 
       RowBox[{"\[CapitalLambda]2", "->", "0"}], ",", 
       RowBox[{"\[CapitalLambda]3", "->", "0"}], ",", 
       RowBox[{"v3", "->", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          SuperscriptBox["v1", "2"], "-", 
          SuperscriptBox["v2", "2"]}], "]"}]}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"FullSimplify", "[", 
  RowBox[{"BBFullDet", "[", "x", "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.927990106039654*^9, 3.927990130304756*^9}, {
   3.92799021495795*^9, 3.927990221432639*^9}, {3.927990327723587*^9, 
