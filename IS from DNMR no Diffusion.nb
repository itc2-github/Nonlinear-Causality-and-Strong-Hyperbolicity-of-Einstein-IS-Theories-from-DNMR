Cell[CellGroupData[{

Cell["Subcase : Linearized Determinant", "Section",
 CellChangeTimes->{{3.9920053541293793`*^9, 
  3.99200537339476*^9}},ExpressionUUID->"12526a5b-21ca-c940-84cf-\
9d4fefb359e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Here", " ", "is", " ", "the", " ", "Linearized", " ", "characteristic", " ",
     "polynomial", " ", "to", " ", "compare", " ", "to", " ", "historical", " ",
     "calculations"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"LinearFullCubic", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"FullCubic", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[CapitalPi]", "->", "0"}], ",", 
         RowBox[{"\[CapitalLambda]1", "->", "0"}], ",", 
         RowBox[{"\[CapitalLambda]2", "->", "0"}], ",", 
         RowBox[{"\[CapitalLambda]3", "->", "0"}], ",", 
         RowBox[{"v3", "->", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "-", 
            SuperscriptBox["v1", "2"], "-", 
            SuperscriptBox["v2", "2"]}], "]"}]}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"FullSimplify", "[", "LinearFullCubic", "]"}]}]}]], "Input",
 CellLabel->"In[26]:=",ExpressionUUID->"b7192fba-a136-c14f-a998-0d094cf16785"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Subcase: Bulk + Baryon Current", "Section",
 CellChangeTimes->{{3.9279900238256164`*^9, 3.9279900387192802`*^9}, 
