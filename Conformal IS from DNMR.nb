Cell[CellGroupData[{

Cell["Subcase : Linearized Conformal Determinant", "Subsection",
 CellChangeTimes->{{3.99200892385845*^9, 
  3.992008942433468*^9}},ExpressionUUID->"2bd128a4-1306-9f43-9c1c-\
f9ec3158a07e"],

Cell["For reference, here is the linear case", "Text",
 CellChangeTimes->{{3.9920089466097317`*^9, 
  3.99200895209009*^9}},ExpressionUUID->"85b882c8-1fdb-fb42-a9c6-\
b2e40349e6a7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"LinearConformalCubic", "[", "y_", "]"}], ":=", 
   RowBox[{
    RowBox[{"ConformalCubic", "[", "y", "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x1", "->", "1"}], ",", 
      RowBox[{"x2", "->", "1"}], ",", 
      RowBox[{"x3", "->", "1"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Factor", "[", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"LinearConformalCubic", "[", "y", "]"}], "]"}], "]"}]}], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"3be92274-7c48-d247-9176-14d8c009cf12"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "3"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "1"}], "+", 
    RowBox[{"3", " ", "y"}], "-", 
    RowBox[{"4", " ", "\[Eta]"}]}], ")"}], " ", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"y", "-", "\[Eta]"}], ")"}], "2"]}]], "Output",
 CellChangeTimes->{3.992008955459751*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"0e778512-76f3-0f48-a3ad-7d7674590264"]
}, Open  ]],

Cell[TextData[{
 "Next, we extract the coefficients of the cubic in order to manually find \
the discriminant. Here, ConfA2, ConfA1 and ConfA0 are the coefficients of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["y", "2"], ",", 
    RowBox[{"y", " ", "and", " ", 
     SuperscriptBox["y", "0"]}]}], TraditionalForm]],ExpressionUUID->
  "fad2e706-b52b-6549-846f-61a34d8182a3"],
 " respectively. ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", "3"], TraditionalForm]],ExpressionUUID->
  "da2f007d-809d-2a42-a966-2ccc99ac21f5"],
 " has coefficient of 1 by construction. Please be patient here - ",
 StyleBox["FullSimplify", "Code"],
 " may take a couple of minutes to compile."
}], "Text",
 CellChangeTimes->{{3.929201576556391*^9, 3.9292017420566645`*^9}, {
  3.929202222065114*^9, 3.929202244276492*^9}, {3.9920092295841713`*^9, 
  3.992009261104452*^9}},ExpressionUUID->"26b8ed17-a4fc-b74d-aecd-\
ce0962de5a53"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ConfA2", "=", 
   RowBox[{"-", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"Coefficient", "[", 
      RowBox[{
       RowBox[{"ConformalCubic", "[", "y", "]"}], ",", "y", ",", "2"}], "]"}],
      "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ConfA1", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Coefficient", "[", 
     RowBox[{
      RowBox[{"ConformalCubic", "[", "y", "]"}], ",", "y", ",", "1"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ConfA0", "=", 
   RowBox[{"-", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"Coefficient", "[", 
      RowBox[{
       RowBox[{"ConformalCubic", "[", "y", "]"}], ",", "y", ",", "0"}], "]"}],
      "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<The following conditions are necessary and sufficient for the \
roots to be in the interval [0,1]\>\"", ",", "\"\<\\n\>\""}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<0 \[LessEqual] \!\(\*FractionBox[SubscriptBox[\(A\), \(2\)], \
\(3\)]\) = \>\"", ",", 
   RowBox[{"Collect", "[", 
    RowBox[{
     FractionBox["ConfA2", "3"], ",", "\[Eta]", ",", "FullSimplify"}], "]"}], 
   ",", "\"\< \[LessEqual] 1\>\""}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<0 \[LessEqual] \!\(\*SubscriptBox[\(A\), \(1\)]\) = \>\"", ",", 
   RowBox[{"Collect", "[", 
    RowBox[{"ConfA1", ",", "\[Eta]", ",", "FullSimplify"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<0 \[LessEqual] \!\(\*SubscriptBox[\(A\), \(0\)]\) = \>\"", ",", 
   RowBox[{"Collect", "[", 
    RowBox[{"ConfA0", ",", "\[Eta]", ",", "FullSimplify"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<0 \[LessEqual] 1 - \!\(\*SubscriptBox[\(A\), \(2\)]\) + \
\!\(\*SubscriptBox[\(A\), \(1\)]\) - \!\(\*SubscriptBox[\(A\), \(0\)]\) = \
\>\"", ",", 
   RowBox[{"Collect", "[", 
    RowBox[{
     RowBox[{"Cancel", "[", 
      RowBox[{"1", "-", "ConfA2", "+", "ConfA1", "-", "ConfA0"}], "]"}], ",", 
     "\[Eta]", ",", "FullSimplify"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<0 \[LessEqual] 1 - \!\(\*FractionBox[\(2\), \
\(3\)]\)\!\(\*SubscriptBox[\(A\), \(2\)]\) + \!\(\*FractionBox[\(1\), \
\(3\)]\)\!\(\*SubscriptBox[\(A\), \(1\)]\) = \>\"", ",", 
   RowBox[{"Collect", "[", 
    RowBox[{
     RowBox[{"Cancel", "[", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "ConfA2"}], "+", "ConfA1", "+", "3"}], "3"], 
      "]"}], ",", "\[Eta]", ",", "FullSimplify"}], "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9349074695775833`*^9, 3.9349075013762875`*^9}, {
