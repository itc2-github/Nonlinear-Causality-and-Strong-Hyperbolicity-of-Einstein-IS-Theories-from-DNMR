Cell[TextData[{
 "To generate various necessary conditions, one can pick various values of \
v1, v2 and v3 (though by our units, note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      SubscriptBox["v", "1"], "2"], "+", 
     SuperscriptBox[
      SubscriptBox["v", "2"], "2"], "+", 
     SuperscriptBox[
      SubscriptBox["v", "3"], "2"]}], "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0064e246-a393-424f-852d-6c8398bd5152"],
 ") and substitute them into the above inequalities. For example (normalizing \
by known positive quantities)"
}], "Text",
 CellChangeTimes->{{3.9920094459824104`*^9, 3.992009541087141*^9}, {
  3.9920097349518356`*^9, 
  3.992009754321726*^9}},ExpressionUUID->"d9d5541a-fb28-f34a-87cb-\
cd3d66551f66"],

