2126577f4d24"],

Cell[CellGroupData[{

Cell["Global Definitions (PLEASE READ AND COMPILE)", "Chapter",
 CellChangeTimes->{{3.926001532405986*^9, 3.926001590717676*^9}, {
   3.927393377909457*^9, 3.9273933840756598`*^9}, {3.9579668799652824`*^9, 
   3.957966906220621*^9}, {3.9920087709441643`*^9, 3.992008776702179*^9}, 
   3.992010033288067*^9, 3.992010103601328*^9, 3.992010197662981*^9, {
   3.992010342180187*^9, 
   3.9920103443085136`*^9}},ExpressionUUID->"c5c600f0-2f2d-4bf8-a3d2-\
d6d02572e612"],

Cell[TextData[{
 "***I\[CloseCurlyQuote]ve copied the code from the main document in order to \
calculate the conformal case. Below are the global definitions and \
calculation of the full cubic.***\n\nNotice that we are working in units of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"E", "=", 
    RowBox[{
     SubscriptBox["\[Tau]", "\[Pi]"], "=", 
     RowBox[{
      SubscriptBox["\[Tau]", "\[CapitalPi]"], "=", "1"}]}]}], 
   TraditionalForm]],ExpressionUUID->"bb918831-b0e2-4d49-9ec7-0c8298b446f6"],
 " (note that we call E0 = E = e + P + \[CapitalPi]), which is the same as \
redefining the transport coefficients and dynamic variables such that\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Zeta]", ",", 
      SubscriptBox["\[Delta]", "\[CapitalPi]\[CapitalPi]"], ",", " ", 
      SubscriptBox["\[Lambda]", "\[CapitalPi]\[Pi]"]}], ")"}], " ", "->"}], 
   TraditionalForm]],ExpressionUUID->"99ed4be7-c69b-0e44-ab5d-9525e964c000"],
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["\[Tau]", "\[CapitalPi]"]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["\[Zeta]", "E"], ",", 
       SubscriptBox["\[Delta]", "\[CapitalPi]\[CapitalPi]"], ",", " ", 
       SubscriptBox["\[Lambda]", "\[CapitalPi]\[Pi]"]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"e20ff9cd-2bcd-b649-bbb4-47b00be191a9"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[Eta]", ",", 
      SubscriptBox["\[Delta]", "\[Pi]\[Pi]"], ",", " ", 
      SubscriptBox["\[Tau]", "\[Pi]\[Pi]"], ",", " ", 
      SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"]}], ")"}], " ", "->"}], 
   TraditionalForm]],ExpressionUUID->"f4ef3696-9ac3-1a47-8820-7cd57d081175"],
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["\[Tau]", "\[Pi]"]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["\[Eta]", "E"], ",", 
       SubscriptBox["\[Delta]", "\[Pi]\[Pi]"], ",", " ", 
       SubscriptBox["\[Tau]", "\[Pi]\[Pi]"], ",", " ", 
       SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"]}], ")"}], " "}]}], 
   TraditionalForm]],ExpressionUUID->"7f4d936e-e399-394a-98aa-20c619c11a27"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalLambda]", "a"], "->", 
    FractionBox[
     SubscriptBox["\[CapitalLambda]", "a"], "E"]}], TraditionalForm]],
  ExpressionUUID->"4b9d4849-9395-b849-9371-24ddcee55de0"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalPi]", "->", 
    FractionBox["\[CapitalPi]", "E"]}], TraditionalForm]],ExpressionUUID->
  "12d4c313-b834-b942-9fe5-3a331a3aaa4e"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", " ", 
     SubscriptBox["P", "n"]}], "->", 
    FractionBox[
     RowBox[{"n", " ", 
      SubscriptBox["P", "n"]}], "E"]}], TraditionalForm]],ExpressionUUID->
  "71155e86-0087-ac48-8882-fd6f9facd448"],
 "\n\nTrimming the amount of symbolic terms will make the calculation run \
quicker.\n\nNote that we also normalize the characteristic vector components \
via ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["v", "2"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalDelta]", "\[Alpha]\[Beta]"], 
      SubscriptBox["\[Phi]", "\[Alpha]"], 
      SubscriptBox["\[Phi]", "\[Beta]"]}], "=", "1"}]}], TraditionalForm]],
  ExpressionUUID->"1b2cbf5f-69ef-ad4e-aab8-fea9d8641505"],
 ", which amounts to writing \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["x", "2"], "->", 
    FractionBox[
     SuperscriptBox["x", "2"], 
     SuperscriptBox["v", "2"]]}], TraditionalForm]],ExpressionUUID->
  "9d16d157-6299-ce44-8291-e01c53616e8a"],
 ", \n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["v", "A"], "2"], "->", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["v", "A"], "2"], 
     SuperscriptBox["v", "2"]]}], TraditionalForm]],ExpressionUUID->
  "dfb1dd29-6e74-154a-b68a-88a6b1f5616a"],
 ".\n\nWe\[CloseCurlyQuote]ll also often write y = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "93350029-9a84-c048-b5eb-1021b8852746"],
 " for aesthetic purposes."
}], "Text",
 CellChangeTimes->{{3.929201576556391*^9, 3.9292017420566645`*^9}, {
   3.929202222065114*^9, 3.929202244276492*^9}, {3.934539091813116*^9, 
   3.934539121130993*^9}, {3.9403447930140533`*^9, 3.9403448253337364`*^9}, {
   3.956063365867159*^9, 3.95606338733729*^9}, {3.9560635028166046`*^9, 
   3.9560637089673195`*^9}, {3.9560642941420803`*^9, 3.956064549274103*^9}, {
   3.992002399830721*^9, 3.992002445131668*^9}, 3.9920024809295387`*^9, {
   3.9920025220960007`*^9, 3.992002645771759*^9}, {3.9920029910804195`*^9, 
   3.9920030110806007`*^9}, {3.9920100798440933`*^9, 
   3.9920100927016563`*^9}, {3.9920102052519474`*^9, 
   3.9920102055325966`*^9}},ExpressionUUID->"a63b46b2-1bc7-434f-9c7b-\
d05536b81773"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{"ATTENTION", ":", " ", 
    RowBox[{
    "The", " ", "below", " ", "code", " ", "is", " ", "for", " ", "the", " ", 
     "general", " ", "IS", " ", "determinant", " ", "from", " ", 
     RowBox[{"DNMR", ".", " ", "The"}], " ", "conformal", " ", "code", " ", 
     "will", " ", "not", " ", "compile", " ", "unless", " ", "this", " ", 
     "cell", " ", "is", " ", 
     RowBox[{"compiled", "."}]}]}], "\[IndentingNewLine]", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Identity", " ", "Tensor"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Delta]", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Set", " ", "relaxation", " ", "times", " ", "and", " ", "E0"}], 
     " ", "=", " ", 
     RowBox[{"e", " ", "+", " ", "P", " ", "+", " ", 
      RowBox[{"\[CapitalPi]", " ", "to", " ", "unity", " ", 
       RowBox[{"(", 
        RowBox[{
        "amounts", " ", "to", " ", "a", " ", "redefinition", " ", "of", " ", 
         "the", " ", "transport", " ", "coeffs"}], ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Tau]\[Pi]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Tau]\[CapitalPi]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"E0", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Eta]AB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";"}], 
   " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Minkowski", " ", "metric", " ", "inverse", " ", 
     SuperscriptBox["\[Eta]", "AB"], " ", "with", " ", "raised", " ", 
     "indices"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Projections", " ", "onto", " ", "the", " ", "characteristic", " ", 
       RowBox[{"vector", ":", " ", 
        SubscriptBox["y", "A"]}]}], " ", "=", " ", 
      RowBox[{
       SubscriptBox["\[Phi]", "\[Alpha]"], 
       SuperscriptBox[
        SubscriptBox["e", "A"], "\[Alpha]"]}]}], ",", " ", 
     RowBox[{
      SubscriptBox["v", "A"], " ", "=", " ", 
      RowBox[{
       SubscriptBox["v", "\[Alpha]"], 
       SuperscriptBox[
        SubscriptBox["e", "A"], "\[Alpha]"]}]}], ",", " ", 
     RowBox[{
      SubscriptBox["y", "0"], " ", "=", " ", "x"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vB", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", "v1", ",", "v2", ",", "v3"}], "}"}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vA", "=", 
     RowBox[{"\[Eta]AB", ".", "vB"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yB", "=", 
     RowBox[{"{", 
      RowBox[{"x", ",", "v1", ",", "v2", ",", "v3"}], "}"}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yA", "=", 
     RowBox[{"\[Eta]AB", ".", "yB"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"v", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"vB", ".", "vA"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Convenient", " ", "substitutions", " ", "for", " ", "inputting", " ", 
     "the", " ", "eigenvalues", " ", 
     SubscriptBox["\[CapitalLambda]", "A"]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]", "=", 
     RowBox[{"{", 
      RowBox[{
      "0", ",", "\[CapitalLambda]1", ",", "\[CapitalLambda]2", ",", 
       "\[CapitalLambda]3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]yB", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"\[CapitalLambda]1", " ", "v1"}], ",", 
       RowBox[{"\[CapitalLambda]2", " ", "v2"}], ",", 
       RowBox[{"\[CapitalLambda]3", " ", "v3"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]yA", "=", 
     RowBox[{"\[Eta]AB", ".", "\[CapitalLambda]yB"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]\[Delta]AB", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "\[CapitalLambda]1", ",", "0", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "\[CapitalLambda]2", ",", "0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "\[CapitalLambda]3"}], "}"}]}], 
      "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Substitutions", " ", "stemming", " ", "from", " ", "coefficients", " ", 
     "of", " ", "the", " ", "original", " ", "principal", " ", "part"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"C\[CapitalPi]B", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Zeta]", "+", 
         RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
        ")"}], "yB"}], "+", 
      RowBox[{"\[Lambda]\[CapitalPi]\[Pi]", " ", "\[CapitalLambda]yB"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"C\[Pi]AB", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "\[Eta]"}], "+", 
         RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], ")"}],
        "*", 
       RowBox[{"(", 
        RowBox[{
         FractionBox[
          RowBox[{"TensorProduct", "[", 
           RowBox[{"vA", ",", "yB"}], "]"}], "6"], "+", 
         FractionBox[
          RowBox[{
           SuperscriptBox["v", "2"], "\[Delta]"}], "2"]}], ")"}]}], "-", 
      RowBox[{"\[Tau]\[Pi]", " ", "x", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"TensorProduct", "[", 
          RowBox[{
           RowBox[{"\[Delta]", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
           "\[CapitalLambda]yB"}], "]"}], "+", 
         RowBox[{"x", " ", "\[CapitalLambda]\[Delta]AB"}]}], ")"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Delta]\[Pi]\[Pi]", "-", 
         FractionBox["\[Tau]\[Pi]\[Pi]", "12"]}], ")"}], 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"\[CapitalLambda]yA", ",", "yB"}], "]"}]}], "+", 
      RowBox[{
       FractionBox["\[Tau]\[Pi]\[Pi]", "4"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["v", "2"], " ", "\[CapitalLambda]\[Delta]AB"}], "+", 
         RowBox[{"\[Delta]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[CapitalLambda]1", " ", 
             SuperscriptBox["v1", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]2", " ", 
             SuperscriptBox["v2", "2"]}], "+", 
            RowBox[{"\[CapitalLambda]3", " ", 
             SuperscriptBox["v3", "2"]}]}], ")"}]}]}], ")"}]}], "-", 
      RowBox[{
       FractionBox["\[Tau]\[Pi]\[Pi]", "12"], 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"vA", ",", "\[CapitalLambda]yB"}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"X", " ", "in", " ", "the", " ", "basis", " ", 
     RowBox[{"{", 
      SuperscriptBox[
       SubscriptBox["e", "A"], "\[Mu]"], "}"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Xtilde", "=", 
     RowBox[{
      RowBox[{"E0", " ", "x", " ", "\[Delta]"}], "-", 
      RowBox[{"TensorProduct", "[", 
       RowBox[{
        RowBox[{"\[Delta]", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
        "\[CapitalLambda]yB"}], "]"}], "-", 
      RowBox[{
       FractionBox["P\[CurlyEpsilon]", "x"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"E0", " ", 
          RowBox[{"TensorProduct", "[", 
           RowBox[{"vA", ",", "yB"}], "]"}]}], "+", 
         RowBox[{"TensorProduct", "[", 
          RowBox[{"vA", ",", "\[CapitalLambda]yB"}], "]"}]}], ")"}]}], "-", 
      RowBox[{
       FractionBox[
        RowBox[{"n", " ", "Pn"}], "x"], 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"vA", ",", "yB"}], "]"}]}], "-", 
      FractionBox[
       RowBox[{"TensorProduct", "[", 
        RowBox[{"vA", ",", "C\[CapitalPi]B"}], "]"}], 
       RowBox[{"\[Tau]\[CapitalPi]", " ", "x"}]], "-", 
      FractionBox["C\[Pi]AB", 
       RowBox[{"\[Tau]\[Pi]", " ", "x"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FullCubic", "[", "y_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Cancel", "[", 
       RowBox[{
        RowBox[{"Det", "[", 
         RowBox[{"x", " ", "Xtilde"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"E0", " ", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["x", "2"], "-", 
            FractionBox[
             RowBox[{
              SuperscriptBox["v1", "2"], " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"2", " ", "\[Eta]"}], "+", 
                   RowBox[{
                   "\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
                  ")"}]}], "+", 
                RowBox[{"\[CapitalLambda]1", " ", "\[Tau]\[Pi]\[Pi]"}]}], 
               ")"}]}], 
             RowBox[{"4", " ", "E0", " ", "\[Tau]\[Pi]"}]], "-", 
            FractionBox[
             RowBox[{
              SuperscriptBox["v2", "2"], " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"2", " ", "\[Eta]"}], "+", 
                   RowBox[{
                   "\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
                  ")"}]}], "+", 
                RowBox[{"\[CapitalLambda]2", " ", "\[Tau]\[Pi]\[Pi]"}]}], 
               ")"}]}], 
             RowBox[{"4", " ", "E0", " ", "\[Tau]\[Pi]"}]], "-", 
            FractionBox[
             RowBox[{
              SuperscriptBox["v3", "2"], " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"2", " ", "\[Eta]"}], "+", 
                   RowBox[{
                   "\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
                  ")"}]}], "+", 
                RowBox[{"\[CapitalLambda]3", " ", "\[Tau]\[Pi]\[Pi]"}]}], 
               ")"}]}], 
             RowBox[{"4", " ", "E0", " ", "\[Tau]\[Pi]"}]]}], ")"}], 
          RowBox[{"(", 
           RowBox[{"E0", "+", "\[CapitalLambda]1"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"E0", "+", "\[CapitalLambda]2"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"E0", "+", "\[CapitalLambda]3"}], ")"}]}], " ", ")"}]}], 
       "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{"x", "->", 
        RowBox[{"Sqrt", "[", "y", "]"}]}], 
       RowBox[{"(*", 
        RowBox[{",", 
         RowBox[{"v3", "->", "\[Kappa]"}], ",", 
         RowBox[{"v2", "->", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              SuperscriptBox["\[Kappa]", "2"]}], ")"}], 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              SuperscriptBox["\[Chi]", "2"]}], ")"}]}], "]"}]}], ",", 
         RowBox[{"v1", "->", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "-", 
              SuperscriptBox["\[Kappa]", "2"]}], ")"}], 
            SuperscriptBox["\[Chi]", "2"]}], "]"}]}]}], "*)"}], "}"}]}]}], 
    ";"}]}]}]], "Input",
