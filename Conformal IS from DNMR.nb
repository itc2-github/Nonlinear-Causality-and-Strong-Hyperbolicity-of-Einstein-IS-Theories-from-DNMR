Cell[CellGroupData[{

Cell["Conformal Limit", "Section",
 CellChangeTimes->{{3.9279900238256164`*^9, 3.9279900387192802`*^9}, 
   3.928085166740244*^9, {3.928598872316504*^9, 3.9285988848076906`*^9}, 
   3.992008764561182*^9},ExpressionUUID->"681826de-81f1-5042-acb2-\
96dd9fa6c753"],

Cell[TextData[{
 "The goal here is to extract the cubic polynomial term in the determinant \
and simplify it. We use the substitution\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "A"], "=", 
    RowBox[{"E", "+", 
     SubscriptBox["\[CapitalLambda]", "A"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "90b4e2ef-db0f-e641-a5ab-dd0c3a4212f1"],
 "\n\nAlong with the usual conformal limit with\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["\[Delta]", "\[Pi]\[Pi]"], 
     SubscriptBox["\[Tau]", "\[Pi]"]], "=", 
    FractionBox["4", "3"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2563e9b7-455b-dc40-8a9d-beb516cf9265"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "\[CurlyEpsilon]"], "=", 
    FractionBox["1", "3"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a5a6c850-094c-8d4e-aada-70aa9ed9b1af"],
 "\n\nAll other second-order transport coefficients are set to zero."
}], "Text",
 CellChangeTimes->{{3.9292015492023563`*^9, 3.929201566225428*^9}, {
  3.9920089862215824`*^9, 3.9920090920927467`*^9}, {3.9920091235212746`*^9, 
  3.992009141446144*^9}},ExpressionUUID->"685d6b77-f971-ae43-ba0e-\
29783a36fc95"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ConformalDet", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", " ", "Xtilde"}], "+", 
      RowBox[{"n", " ", "Pn", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"vA", ",", "yB"}], "]"}]}], "+", 
      FractionBox[
       RowBox[{"TensorProduct", "[", 
        RowBox[{"vA", ",", "C\[CapitalPi]B"}], "]"}], "\[Tau]\[CapitalPi]"]}],
      ")"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[CapitalPi]", "->", "0"}], ",", 
      RowBox[{"P\[CurlyEpsilon]", "->", 
       RowBox[{"1", "/", "3"}]}], ",", 
      RowBox[{"\[Delta]\[Pi]\[Pi]", "->", 
       RowBox[{
        FractionBox["4", "3"], "\[Tau]\[Pi]"}]}], ",", 
      RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", "->", "0"}], ",", 
      RowBox[{"\[Lambda]\[CapitalPi]\[Pi]", "->", "0"}], ",", 
      RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", "->", "0"}], ",", 
      RowBox[{"\[Tau]\[Pi]\[Pi]", "->", "0"}], ",", 
      RowBox[{"\[CapitalLambda]1", "->", 
       RowBox[{"x1", "-", "E0"}]}], ",", 
      RowBox[{"\[CapitalLambda]2", "->", 
       RowBox[{"x2", "-", "E0"}]}], ",", 
      RowBox[{"\[CapitalLambda]3", "->", 
       RowBox[{"x3", "-", "E0"}]}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "ConformalCubic", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ConformalCubic", "[", "y_", "]"}], ":=", 
   RowBox[{"Assuming", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SuperscriptBox["v1", "2"], "+", 
        SuperscriptBox["v2", "2"], "+", 
        SuperscriptBox["v3", "2"]}], "==", "1"}], "}"}], ",", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{"Cancel", "[", 
        FractionBox[
         RowBox[{"Det", "[", "ConformalDet", "]"}], 
         RowBox[{"x1", " ", "x2", " ", "x3", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"E0", " ", 
             SuperscriptBox["x", "2"]}], "-", 
            FractionBox[
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["v1", "2"], "+", 
                SuperscriptBox["v2", "2"], "+", 
                SuperscriptBox["v3", "2"]}], ")"}], " ", "\[Eta]"}], 
             "\[Tau]\[Pi]"]}], ")"}]}]], "]"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{"x", "->", 
        RowBox[{"Sqrt", "[", "y", "]"}]}], "}"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Collect", "[", 
  RowBox[{
   RowBox[{"ConformalCubic", "[", "y", "]"}], ",", "y", ",", "FullSimplify"}],
   "]"}]}], "Input",
 CellChangeTimes->{{3.928598925143197*^9, 3.928599121966462*^9}, {
