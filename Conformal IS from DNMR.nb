Cell[CellGroupData[{
Cell["IS from DNMR in the Conformal Limit", "Title",
 CellChangeTimes->{{3.92426922538381*^9, 3.9242692362351856`*^9}, {
   3.957966788138052*^9, 3.9579667958819256`*^9}, {3.960471837900011*^9, 
