  RowBox[{"\"\<0 \[LessEqual] \>\"", ",", 
   RowBox[{"Collect", "[", 
    RowBox[{
     RowBox[{
      FractionBox["ConfA0", 
       FractionBox["\[Eta]", 
        RowBox[{"3", "x1", " ", "x2", " ", "x3"}]]], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"v1", "->", 
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", 
        RowBox[{"v2", "->", "0"}], ",", 
        RowBox[{"v3", "->", 
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], "}"}]}], ",", "\[Eta]", ",", 
     "FullSimplify"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.968415135023468*^9, 3.96841522833181*^9}, {
  3.9920095602795353`*^9, 3.992009590153324*^9}, {3.99200964137961*^9, 
