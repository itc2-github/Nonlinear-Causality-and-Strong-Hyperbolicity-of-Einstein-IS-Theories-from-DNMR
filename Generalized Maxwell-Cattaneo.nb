Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["v3", "2"], " ", 
   RowBox[{"(", 
    RowBox[{"x1", "-", "x3"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "x2"}], "+", "x3"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Pe", " ", "x3"}], "+", "\[Zeta]eff"}], ")"}], " ", 
