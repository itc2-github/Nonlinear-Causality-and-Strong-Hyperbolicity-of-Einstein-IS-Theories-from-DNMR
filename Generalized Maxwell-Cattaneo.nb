   3.9260020171360564`*^9, 3.9260020441433144`*^9}, {3.9260021156347575`*^9, 
   3.9260024714980817`*^9}, {3.9260025597452526`*^9, 
   3.9260027278556705`*^9}, {3.926003356775174*^9, 3.926003547332262*^9}, {
   3.9260037265563836`*^9, 3.9260038795908413`*^9}, {3.9260039502133827`*^9, 
