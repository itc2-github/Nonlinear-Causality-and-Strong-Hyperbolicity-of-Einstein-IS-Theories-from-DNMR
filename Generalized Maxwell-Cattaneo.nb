Cell[CellGroupData[{

Cell["Generalized Maxwell - Cattaneo", "Chapter",
 CellChangeTimes->{{3.9279900238256164`*^9, 3.9279900387192802`*^9}, 
   3.928085166740244*^9, 3.9560629231823196`*^9, 3.957969804204319*^9, {
   3.9920065846148205`*^9, 
   3.992006586282696*^9}},ExpressionUUID->"f568f19e-8c5d-4071-94d3-\
339178723a46"],

Cell[TextData[{
 "Here is the cubic appearing the the characteristic determinant. Here y = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SuperscriptBox["x", "2"], 
    SuperscriptBox["v", "2"]], TraditionalForm]],ExpressionUUID->
  "40d46053-78c0-4524-af4d-f055efb558c7"],
 ". Please note that we have introduced\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Zeta]", "eff"], "=", 
    RowBox[{"\[Zeta]", "+", 
     RowBox[{"n", " ", 
      SubscriptBox["P", "n"]}], "-", 
     RowBox[{
      SubscriptBox["\[Eta]", "eff"], "/", "3"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "08cec30b-db01-be4b-bb6d-5ac41b56da07"],
 "\n\nin terms of dimensionless relaxation times ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "\[Pi]"], "=", 
    RowBox[{
     SubscriptBox["\[Tau]", "\[CapitalPi]"], "=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6c3d00ef-8991-eb47-a461-c1d9063988d4"],
 ". The generalized Maxwell-Cattaneo case considers direct second-order \
corrections to the first-order \[Eta] and \[Zeta] terms. Anything else is set \
to zero. Although ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9f759ba5-74cd-6d4d-83ab-a6ba5a7207a2"],
 " was set to zero below, you should interpret any mention of \[Eta] instead \
as the generalized term \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Eta]", "->", 
     SubscriptBox["\[Eta]", "eff"]}], "=", 
    RowBox[{"\[Eta]", "+", 
     FractionBox[
      RowBox[{
       SubscriptBox["\[Lambda]", "\[Pi]\[CapitalPi]"], "\[CapitalPi]"}], 
      "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4f95ce06-8aef-4e42-b68c-c1c1ce65e12e"]
}], "Text",
 CellChangeTimes->{{3.9279906639874725`*^9, 3.9279906961164184`*^9}, {
  3.9280851272293177`*^9, 3.9280851425067015`*^9}, {3.9920103633706093`*^9, 
  3.9920105037550354`*^9}, {3.9920105340678177`*^9, 3.9920106156750374`*^9}, {
  3.9920106559689865`*^9, 
  3.992010656685837*^9}},ExpressionUUID->"f393c55e-7a1e-4d01-9886-\
78763e72211f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MCcubic", "[", "y_", "]"}], ":=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Cancel", "[", 
       FractionBox[
        RowBox[{"Det", "[", 
         RowBox[{"x", " ", "Xtilde"}], "]"}], 
        RowBox[{
         RowBox[{"m", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", 
         RowBox[{"(", 
          RowBox[{"E0", "+", "\[CapitalLambda]1"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"E0", "+", "\[CapitalLambda]2"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"E0", "+", "\[CapitalLambda]3"}], ")"}]}]], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[CapitalLambda]1", "->", 
         RowBox[{"x1", "-", "E0"}]}], ",", 
        RowBox[{"\[CapitalLambda]2", "->", 
         RowBox[{"x2", "-", "E0"}]}], ",", 
        RowBox[{"\[CapitalLambda]3", "->", 
         RowBox[{"x3", "-", "E0"}]}], ",", 
        RowBox[{"x", "->", 
         RowBox[{"Sqrt", "[", "y", "]"}]}], ",", 
        RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", "->", "0"}], ",", 
        RowBox[{"\[Lambda]\[CapitalPi]\[Pi]", "->", "0"}], ",", 
        RowBox[{"\[Delta]\[Pi]\[Pi]", "->", "0"}], ",", 
        RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", "->", "0"}], ",", 
        RowBox[{"\[Zeta]", "->", 
         RowBox[{"\[Zeta]eff", "-", 
          RowBox[{"n", " ", "Pn"}], "-", 
          FractionBox["\[Eta]", "3"]}]}], ",", 
        RowBox[{"\[Tau]\[Pi]\[Pi]", "->", "0"}]}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Useful", " ", "substitutions"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"G", "[", "\[Beta]_", "]"}], ":=", 
   FractionBox[
    RowBox[{
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "\[Eta]"}], "+", 
        RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
       ")"}]}], "+", 
     RowBox[{"\[Tau]\[Pi]\[Pi]", " ", 
      RowBox[{"\[CapitalLambda]", "[", 
       RowBox[{"[", "\[Beta]", "]"}], "]"}]}]}], 
    RowBox[{"4", "E0", " ", "\[Tau]\[Pi]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m", ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"E0", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["x", "2"], "-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"G", "[", "2", "]"}], 
           SuperscriptBox["v1", "2"]}], "+", 
          RowBox[{
           RowBox[{"G", "[", "3", "]"}], 
           SuperscriptBox["v2", "2"]}], "+", 
          RowBox[{
           RowBox[{"G", "[", "4", "]"}], 
           SuperscriptBox["v3", "2"]}]}], ")"}]}], ")"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"E0", "+", "\[CapitalLambda]1"}], ")"}], 
       SuperscriptBox["x", "2"]}], "-", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "\[Eta]"}], "+", 
          RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
         ")"}], 
        SuperscriptBox["v", "2"]}], 
       RowBox[{"2", "\[Tau]\[Pi]"}]], "-", 
      FractionBox[
       RowBox[{"\[Tau]\[Pi]\[Pi]", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalLambda]1", " ", 
           SuperscriptBox["v", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]1", " ", 
           SuperscriptBox["v1", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]2", " ", 
           SuperscriptBox["v2", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]3", " ", 
           SuperscriptBox["v3", "2"]}]}], ")"}]}], 
       RowBox[{"4", "\[Tau]\[Pi]"}]]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"E0", "+", "\[CapitalLambda]2"}], ")"}], 
       SuperscriptBox["x", "2"]}], "-", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "\[Eta]"}], "+", 
          RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
         ")"}], 
        SuperscriptBox["v", "2"]}], 
       RowBox[{"2", "\[Tau]\[Pi]"}]], "-", 
      FractionBox[
       RowBox[{"\[Tau]\[Pi]\[Pi]", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalLambda]2", " ", 
           SuperscriptBox["v", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]1", " ", 
           SuperscriptBox["v1", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]2", " ", 
           SuperscriptBox["v2", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]3", " ", 
           SuperscriptBox["v3", "2"]}]}], ")"}]}], 
       RowBox[{"4", "\[Tau]\[Pi]"}]]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"E0", "+", "\[CapitalLambda]3"}], ")"}], 
       SuperscriptBox["x", "2"]}], "-", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "\[Eta]"}], "+", 
          RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", " ", "\[CapitalPi]"}]}], 
         ")"}], 
        SuperscriptBox["v", "2"]}], 
       RowBox[{"2", "\[Tau]\[Pi]"}]], "-", 
      FractionBox[
       RowBox[{"\[Tau]\[Pi]\[Pi]", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[CapitalLambda]3", " ", 
           SuperscriptBox["v", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]1", " ", 
           SuperscriptBox["v1", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]2", " ", 
           SuperscriptBox["v2", "2"]}], "+", 
          RowBox[{"\[CapitalLambda]3", " ", 
           SuperscriptBox["v3", "2"]}]}], ")"}]}], 
       RowBox[{"4", "\[Tau]\[Pi]"}]]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"m", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "->", 
       RowBox[{"Sqrt", "[", "y", "]"}]}], ",", 
      RowBox[{"\[Tau]\[Pi]", "->", "\[Tau]\[CapitalPi]"}], ",", 
      RowBox[{"\[Lambda]\[Pi]\[CapitalPi]", "->", "0"}], ",", 
      RowBox[{"\[Lambda]\[CapitalPi]\[Pi]", "->", "0"}], ",", 
      RowBox[{"\[Delta]\[Pi]\[Pi]", "->", "0"}], ",", 
      RowBox[{"\[Delta]\[CapitalPi]\[CapitalPi]", "->", "0"}], ",", 
      RowBox[{"\[Tau]\[Pi]\[Pi]", "->", "0"}], ",", 
      RowBox[{"v3", "->", 
       RowBox[{"Sqrt", "[", "\[Kappa]", "]"}]}], ",", 
      RowBox[{"v2", "->", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Kappa]"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Chi]"}], ")"}]}], "]"}]}], ",", 
      RowBox[{"v1", "->", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Kappa]"}], ")"}], "\[Chi]"}], "]"}]}]}], 
     "}"}]}], "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"MCcubic", "[", "y", "]"}], "==", "0"}], "&&", 
      RowBox[{
       RowBox[{
       "\[CapitalLambda]1", "+", "\[CapitalLambda]2", "+", 
        "\[CapitalLambda]3"}], "==", "0"}], "&&", 
      RowBox[{
       RowBox[{"-", "1"}], "<=", "\[Kappa]", "<=", "1"}], "&&", 
      RowBox[{
       RowBox[{"-", "1"}], "<=", "\[Chi]", "<=", "1"}]}], ",", "y"}], "]"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Assuming", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["v1", "2"], "+", 
      SuperscriptBox["v2", "2"], "+", 
      SuperscriptBox["v3", "2"]}], "==", "1"}], "}"}], ",", 
   RowBox[{"Collect", "[", 
    RowBox[{
     RowBox[{"MCcubic", "[", "y", "]"}], ",", "y", ",", "FullSimplify"}], 
    "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.927990106039654*^9, 3.927990130304756*^9}, {
   3.92799021495795*^9, 3.927990221432639*^9}, {3.927990327723587*^9, 
