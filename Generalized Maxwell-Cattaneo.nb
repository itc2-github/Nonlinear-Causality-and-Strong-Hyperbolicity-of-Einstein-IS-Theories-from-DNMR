          RowBox[{"x1", "-", "x3"}], ")"}], " ", "\[Zeta]eff"}], "+", 
        RowBox[{
         SuperscriptBox["v2", "2"], " ", 
         RowBox[{"(", 
          RowBox[{"x1", "-", "x2"}], ")"}], " ", "x3", " ", "\[Zeta]eff"}], "+", 
        RowBox[{"x2", " ", "x3", " ", "\[Zeta]eff"}], "+", 
