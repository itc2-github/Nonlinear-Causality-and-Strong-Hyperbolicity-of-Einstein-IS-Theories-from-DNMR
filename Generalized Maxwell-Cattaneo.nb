 RowBox[{"Print", "[", 
  RowBox[{"\"\<min \!\(\*SubscriptBox[\(A\), \(2\)]\) = \>\"", ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Minimize", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"MCA2", ",", 
        RowBox[{
         RowBox[{"0", "<=", "\[Kappa]", "<=", "1"}], "&&", 
         RowBox[{"0", "<=", "\[Chi]", "<=", "1"}], "&&", 
         RowBox[{"0", "<", "\[Eta]", "<=", "1"}], "&&", 
         RowBox[{"x1", "<=", "x2", "<=", "x3"}], "&&", 
         RowBox[{"x3", ">", "1"}], "&&", 
         RowBox[{"0", "<=", "x1", "<", "1"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Chi]", ",", "\[Kappa]"}], "}"}]}], "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<max \!\(\*SubscriptBox[\(A\), \(2\)]\) = \>\"", ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Maximize", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"MCA2", ",", 
        RowBox[{
         RowBox[{"0", "<=", "\[Kappa]", "<=", "1"}], "&&", 
         RowBox[{"0", "<=", "\[Chi]", "<=", "1"}], "&&", 
         RowBox[{"0", "<", "\[Eta]", "<=", "1"}], "&&", 
         RowBox[{"x1", "<=", "x2", "<=", "x3"}], "&&", 
