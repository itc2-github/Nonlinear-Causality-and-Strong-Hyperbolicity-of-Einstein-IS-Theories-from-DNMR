 CellLabel->"Out[55]=",ExpressionUUID->"2a2954bd-c62f-e848-a714-47564a6ddfa4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "a. Consider the case ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalLambda]", "1"], "=", 
    SubscriptBox["\[CapitalLambda]", "2"]}], TraditionalForm]],ExpressionUUID->
  "067de077-d672-654c-ad7c-2a017476a7b8"]
}], "Subsection",
 CellChangeTimes->{{3.9587515042850647`*^9, 3.9587515458729496`*^9}, {
  3.9594435392007656`*^9, 3.95944357497027*^9}, {3.992007603724903*^9, 
