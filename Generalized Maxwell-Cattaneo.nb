 RowBox[{"Print", "[", 
  RowBox[{"\"\<min{1 - \!\(\*SubscriptBox[\(A\), \(2\)]\) + \
\!\(\*SubscriptBox[\(A\), \(1\)]\) - \!\(\*SubscriptBox[\(A\), \(0\)]\)} = \>\
\"", ",", "\[IndentingNewLine]", 
   RowBox[{"Assuming", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"0", "<=", "\[Kappa]", "<=", "1"}], "&&", 
       RowBox[{"0", "<=", "\[Chi]", "<=", "1"}], "&&", 
       RowBox[{"0", "<", "\[Eta]", "<=", "1"}], "&&", 
       RowBox[{"x1", "<=", "x2", "<=", "x3"}], "&&", 
