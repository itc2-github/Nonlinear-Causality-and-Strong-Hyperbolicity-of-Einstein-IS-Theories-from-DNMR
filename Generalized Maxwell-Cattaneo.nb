        RowBox[{"x1", " ", "x3", " ", "\[Eta]"}], "+", 
        RowBox[{"x2", " ", "x3", " ", "\[Eta]"}]}], ")"}], 
      RowBox[{"x1", " ", "x2", " ", "x3"}]], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"v1", "->", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"\[Chi]", 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Kappa]"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"v2", "->", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Chi]"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Kappa]"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"v3", "->", 
        RowBox[{"Sqrt", "[", "\[Kappa]", "]"}]}]}], "}"}]}], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<min \!\(\*SubscriptBox[\(A\), \(0\)]\) = \>\"", ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Minimize", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"MCA0", ",", 
        RowBox[{
         RowBox[{"0", "<=", "\[Kappa]", "<=", "1"}], "&&", 
         RowBox[{"0", "<=", "\[Chi]", "<=", "1"}], "&&", 
         RowBox[{"0", "<", "\[Eta]", "<=", "1"}], "&&", 
         RowBox[{"x1", "<=", "x2", "<=", "x3"}], "&&", 
         RowBox[{"x3", ">", "1"}], "&&", 
         RowBox[{"0", "<=", "x1", "<", "1"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Chi]", ",", "\[Kappa]"}], "}"}]}], "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<min \!\(\*SubscriptBox[\(A\), \(1\)]\) = \>\"", ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Minimize", "[", 
     RowBox[{
