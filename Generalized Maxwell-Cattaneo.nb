Cell[CellGroupData[{

Cell["I. Angle - Independent Causality Conditions", "Section",
 CellChangeTimes->{{3.9579669468921547`*^9, 3.9579669632903996`*^9}, {
  3.992007309396551*^9, 
  3.992007309923172*^9}},ExpressionUUID->"0b0cf3aa-aece-0a4e-b9d5-\
b94d224c2be5"],

Cell["\<\
Below, we minimize/maximize the nonlinear causality conditions found for \
Maxwell-Cattaneo using rudimentary calculus techniques. Most of the \
conditions can be extremized using Mathematica\[CloseCurlyQuote]s built in \
Minimize[] and Maximize[] functions, whereas the reality conditions need to \
be approached directly. We start with the former. Below are the coefficients \
of the nontrivial cubic portion of the determinant and sums thereof:\
\>", "Text",
 CellChangeTimes->{{3.9561568055392456`*^9, 3.956156814661175*^9}, {
  3.957966967645136*^9, 
  3.9579670778512135`*^9}},ExpressionUUID->"6be91e8c-eb31-0b41-b4c4-\
10db621b7964"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"MCA0", "=", 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\[Eta]", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Pe", " ", 
          RowBox[{"(", 
           RowBox[{"x1", "+", 
            RowBox[{
             SuperscriptBox["v2", "2"], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "x1"}], "+", "x2"}], ")"}]}], "+", 
            RowBox[{
             SuperscriptBox["v3", "2"], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "x1"}], "+", "x3"}], ")"}]}]}], ")"}]}], "+", 
         "\[Zeta]eff", "+", "\[Eta]"}], ")"}]}], 
      RowBox[{"x1", " ", "x2", " ", "x3"}]], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"v1", "->", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"\[Chi]", 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Kappa]"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"v2", "->", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Chi]"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Kappa]"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"v3", "->", 
        RowBox[{"Sqrt", "[", "\[Kappa]", "]"}]}]}], "}"}]}], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MCA1", "=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"x1", " ", "x2", " ", "x3"}]], 
      RowBox[{"\[Eta]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Pe", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x1", " ", "x2"}], "+", 
            RowBox[{"x1", " ", "x3"}], "+", 
            RowBox[{
             SuperscriptBox["v2", "2"], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "x1"}], "+", "x2"}], ")"}], " ", "x3"}], "+", 
            RowBox[{
             SuperscriptBox["v3", "2"], " ", "x2", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "x1"}], "+", "x3"}], ")"}]}]}], ")"}]}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             SuperscriptBox["v2", "2"], " ", 
             RowBox[{"(", 
              RowBox[{"x1", "-", "x2"}], ")"}]}], "+", "x2", "+", 
            RowBox[{
             SuperscriptBox["v3", "2"], " ", 
             RowBox[{"(", 
              RowBox[{"x1", "-", "x3"}], ")"}]}], "+", "x3"}], ")"}], " ", 
          "\[Zeta]eff"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x1", "+", "x2", "+", "x3"}], ")"}], " ", "\[Eta]"}]}], 
        ")"}]}]}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"v1", "->", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"\[Chi]", 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Kappa]"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"v2", "->", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Chi]"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", "\[Kappa]"}], ")"}]}], "]"}]}], ",", 
       RowBox[{"v3", "->", 
        RowBox[{"Sqrt", "[", "\[Kappa]", "]"}]}]}], "}"}]}], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
