Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Q12quadratic", "=", 
  RowBox[{"Assuming", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["v1", "2"], "+", 
