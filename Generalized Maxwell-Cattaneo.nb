Notebook[{

Cell[CellGroupData[{
Cell["Generalized Maxwell-Cattaneo without Diffusion", "Title",
 CellChangeTimes->{{3.92426922538381*^9, 3.9242692362351856`*^9}, {
  3.957966788138052*^9, 3.9579667958819256`*^9}, {3.9920063879796715`*^9, 
  3.992006389595604*^9}, {3.9920064197185516`*^9, 
  3.9920064215082607`*^9}},ExpressionUUID->"7b130b4c-4e47-4466-bfd7-\
26c25e2d9c66"],

