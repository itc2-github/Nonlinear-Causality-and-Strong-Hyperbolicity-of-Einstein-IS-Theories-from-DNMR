  3.992008103833599*^9}},ExpressionUUID->"103f51f5-c2e0-044d-9724-\
d9f821a7d7ed"],

Cell[TextData[{
 "We print the resulting decoupled quadratic arising as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "3"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["x", "2"], "-", 
       SuperscriptBox[
        SubscriptBox["z", "1"], "2"]}], ")"}], 
     SubscriptBox["Q", "13"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6019a9b2-65d5-bc41-9578-bb456dc92032"]
}], "Text",
 CellChangeTimes->{{3.9920077163214455`*^9, 
  3.9920078052921486`*^9}},ExpressionUUID->"a9a47b7d-0aa8-0641-835a-\
29dffe9988a5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Q13quadratic", "=", 
  RowBox[{"Assuming", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["v1", "2"], "+", 
       SuperscriptBox["v2", "2"], "+", 
       SuperscriptBox["v3", "2"]}], "==", "1"}], "}"}], ",", 
    RowBox[{"Collect", "[", 
     RowBox[{
      RowBox[{"Cancel", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"MCcubic", "[", "y", "]"}], 
         RowBox[{"y", "-", 
          FractionBox["\[Eta]", "x1"]}]], "/.", 
        RowBox[{"{", 
         RowBox[{"x2", "->", "x1"}], "}"}]}], "]"}], ",", "y", ",", 
      "FullSimplify"}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9594435788439693`*^9, 3.9594436830873985`*^9}, {
  3.9594437440616627`*^9, 3.959443769045767*^9}, {3.959443802214573*^9, 
  3.9594438251630497`*^9}, {3.992007741808962*^9, 3.9920077464888287`*^9}, {
  3.992007983781639*^9, 3.9920079843859463`*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"d54225e2-bff1-cb4b-9ba2-89da9f27e718"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["y", "2"], "+", 
  FractionBox[
   RowBox[{"\[Eta]", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pe", " ", 
       RowBox[{"(", 
        RowBox[{"x1", "+", 
         RowBox[{
          SuperscriptBox["v3", "2"], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "x1"}], "+", "x3"}], ")"}]}]}], ")"}]}], "+", 
      "\[Zeta]eff", "+", "\[Eta]"}], ")"}]}], 
   RowBox[{"x1", " ", "x3"}]], "-", 
  FractionBox[
   RowBox[{"y", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pe", " ", "x1", " ", "x3"}], "+", 
      RowBox[{
       SuperscriptBox["v3", "2"], " ", 
       RowBox[{"(", 
        RowBox[{"x1", "-", "x3"}], ")"}], " ", "\[Zeta]eff"}], "+", 
      RowBox[{"x3", " ", "\[Zeta]eff"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x1", "+", "x3"}], ")"}], " ", "\[Eta]"}]}], ")"}]}], 
   RowBox[{"x1", " ", "x3"}]]}]], "Output",
 CellChangeTimes->{{3.9594436020345745`*^9, 3.9594436209088974`*^9}, {
