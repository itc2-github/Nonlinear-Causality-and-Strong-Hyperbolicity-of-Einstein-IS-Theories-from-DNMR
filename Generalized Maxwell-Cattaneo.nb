Cell[CellGroupData[{

Cell["II. Removing the discriminant condition", "Section",
 CellChangeTimes->{{3.992007286818163*^9, 
  3.9920073034626865`*^9}},ExpressionUUID->"00c61444-ce23-b24f-9db4-\
401cd6eac7ba"],

Cell[TextData[{
 "Define special \[OpenCurlyDoubleQuote]indicator points\
\[CloseCurlyDoubleQuote] ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "34429af4-6ec7-ca40-a42c-7e0b6bbb288a"],
 " = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    SubscriptBox["z", "a"], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4ce553b2-7099-9f46-958c-63c6142ecf2c"],
 " for a = 1,2,3, which will be used to determine how many crossing the cubic \
encounters over the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["x", "2"], "-"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "14c15429-bac2-f044-adbc-0bf7b75265db"],
 "axis"
}], "Text",
 CellChangeTimes->{{3.9597815016555805`*^9, 3.959781519179901*^9}, {
  3.992006748034136*^9, 3.992006769639799*^9}, {3.9920073581091213`*^9, 
  3.992007446041443*^9}},ExpressionUUID->"65e21b5f-2895-124c-92f5-\
000873a38697"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"y1hat", "=", 
   FractionBox["\[Eta]", "x1"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y2hat", "=", 
   FractionBox["\[Eta]", "x2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y3hat", "=", 
    FractionBox["\[Eta]", "x3"]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Here", " ", "is", " ", "the", " ", "cubic", " ", "polynomial", " ", 
    "evaluated", " ", "at", " ", "each", " ", "of", " ", "these", " ", 
    "points"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Assuming", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["v1", "2"], "+", 
      SuperscriptBox["v2", "2"], "+", 
      SuperscriptBox["v3", "2"]}], "==", "1"}], "}"}], ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"MCcubic", "[", "y1hat", "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Assuming", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["v1", "2"], "+", 
      SuperscriptBox["v2", "2"], "+", 
      SuperscriptBox["v3", "2"]}], "==", "1"}], "}"}], ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"MCcubic", "[", "y2hat", "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Assuming", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["v1", "2"], "+", 
      SuperscriptBox["v2", "2"], "+", 
      SuperscriptBox["v3", "2"]}], "==", "1"}], "}"}], ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"MCcubic", "[", "y3hat", "]"}], "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9597815273804016`*^9, 3.9597816950489273`*^9}, {
  3.9920074492838078`*^9, 3.992007483334448*^9}, {3.9920080374320564`*^9, 
  3.992008043818262*^9}},
 CellLabel->"In[50]:=",ExpressionUUID->"1132e716-d250-1d47-9fa2-552088e9b293"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     SuperscriptBox["v2", "2"], "+", 
     SuperscriptBox["v3", "2"]}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"x1", "-", "x2"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"x1", "-", "x3"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Pe", " ", "x1"}], "+", "\[Zeta]eff"}], ")"}], " ", 
   SuperscriptBox["\[Eta]", "2"]}], 
  RowBox[{
   SuperscriptBox["x1", "3"], " ", "x2", " ", "x3"}]]], "Output",
 CellChangeTimes->{{3.9597816744427223`*^9, 3.9597816959183025`*^9}, 
   3.99200709238463*^9, 3.9920074868251343`*^9, 3.992008045228359*^9},
 CellLabel->"Out[53]=",ExpressionUUID->"230feea4-5b4e-cd47-bffa-dddae75ebf6c"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["v2", "2"], " ", 
   RowBox[{"(", 
    RowBox[{"x1", "-", "x2"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"x2", "-", "x3"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Pe", " ", "x2"}], "+", "\[Zeta]eff"}], ")"}], " ", 
   SuperscriptBox["\[Eta]", "2"]}], 
  RowBox[{"x1", " ", 
